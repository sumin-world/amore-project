# Database Configuration (REQUIRED)
# SQLite for local development
DATABASE_URL=sqlite+pysqlite:///./data/laneige_insight.db
# PostgreSQL for production (example)
# DATABASE_URL=postgresql://user:password@localhost:5432/laneige_insight

# Request Rate Limiting (OPTIONAL, default: 1.2)
# Sleep duration between HTTP requests in seconds
# Lower values = faster but risk bot detection
# Higher values = slower but safer
REQUEST_SLEEP_SEC=1.2

# LLM Configuration (OPTIONAL)
# Groq API (Free tier, recommended for Why Reports)
USE_GROQ=true
GROQ_API_KEY=

# Claude API (Paid tier, alternative for Why Reports)
USE_CLAUDE=false
ANTHROPIC_API_KEY=

# Note: If both LLM APIs are disabled or unavailable,
# the system will use rule-based fallback for Why Reports

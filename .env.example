# Database (required)
DATABASE_URL=sqlite+pysqlite:///./data/market_insight.db

# Rate limiting (optional, default: 1.2s)
REQUEST_SLEEP_SEC=1.2

# LLM — Groq free tier (optional, recommended)
USE_GROQ=true
GROQ_API_KEY=

# LLM — Claude paid tier (optional)
USE_CLAUDE=false
ANTHROPIC_API_KEY=

# Keepa API (optional, for ToS-friendly collection)
KEEPA_API_KEY=

# Product config file (optional, default: config/products.json)
# PRODUCTS_CONFIG=config/products.json

# Demo mode — disables live scraping
DEMO_MODE=false
